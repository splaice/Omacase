{
  "document": { "block_prefix": "\n", "block_suffix": "\n", "margin": 2 },
  "block_quote": { "indent": 1, "indent_token": "│ ", "color": "8" },
  "paragraph": {},
  "list": { "level_indent": 2 },
  "heading": { "block_suffix": "\n", "color": "5", "bold": true },
  "h1": { "prefix": " ", "suffix": " ", "color": "0", "background_color": "5", "bold": true },
  "h2": { "prefix": "## ", "color": "13" },
  "h3": { "prefix": "### ", "color": "5" },
  "h4": { "prefix": "#### ", "color": "13" },
  "h5": { "prefix": "##### ", "color": "5" },
  "h6": { "prefix": "###### ", "color": "8", "bold": false },
  "text": {},
  "strikethrough": { "crossed_out": true },
  "emph": { "italic": true },
  "strong": { "bold": true },
  "hr": { "color": "8", "format": "\n--------\n" },
  "item": { "block_prefix": "• " },
  "enumeration": { "block_prefix": ". " },
  "task": { "ticked": "[✓] ", "unticked": "[ ] " },
  "link": { "color": "6", "underline": true },
  "link_text": { "color": "5", "bold": true },
  "image": { "color": "5", "underline": true },
  "image_text": { "color": "8", "format": "Image: {{.text}} →" },
  "code": { "prefix": " ", "suffix": " ", "color": "2", "background_color": "8" },
  "code_block": {
    "margin": 2,
    "chroma": {
      "text": {},
      "error": { "color": "1" },
      "comment": { "color": "8", "italic": true },
      "comment_preproc": { "color": "3" },
      "keyword": { "color": "13" },
      "keyword_reserved": { "color": "13" },
      "keyword_namespace": { "color": "13" },
      "keyword_type": { "color": "4" },
      "operator": { "color": "7" },
      "punctuation": { "color": "7" },
      "name": {},
      "name_builtin": { "color": "13" },
      "name_tag": { "color": "5" },
      "name_attribute": { "color": "3" },
      "name_class": { "color": "4", "bold": true },
      "name_constant": { "color": "3" },
      "name_decorator": { "color": "3" },
      "name_function": { "color": "5", "bold": true },
      "literal": {},
      "literal_number": { "color": "3" },
      "literal_string": { "color": "2" },
      "literal_string_escape": { "color": "6" },
      "generic_deleted": { "color": "1" },
      "generic_emph": { "italic": true },
      "generic_inserted": { "color": "2" },
      "generic_strong": { "bold": true },
      "generic_subheading": { "color": "8" }
    }
  },
  "table": {},
  "definition_list": {},
  "definition_term": {},
  "definition_description": { "block_prefix": "\n🠶 " },
  "html_block": {},
  "html_span": {}
}
