# Catppuccin Mocha — Starship prompt (used as $STARSHIP_CONFIG via theme.toml).
"$schema" = 'https://starship.rs/config-schema.json'
add_newline = true
palette = 'mocha'
format = '$directory$git_branch$git_status$nodejs$python$character'

[palettes.mocha]
blue = '#89b4fa'
green = '#a6e3a1'
red = '#f38ba8'
mauve = '#cba6f7'
yellow = '#f9e2af'

[directory]
style = 'bold blue'
truncation_length = 3
truncate_to_repo = true

[git_branch]
symbol = ' '
style = 'bold mauve'

[git_status]
style = 'bold red'

[nodejs]
symbol = ' '
style = 'green'

[python]
symbol = ' '
style = 'yellow'

[character]
success_symbol = '[➜](bold green)'
error_symbol = '[➜](bold red)'
