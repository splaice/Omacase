{
  "document": {
    "block_prefix": "\n",
    "block_suffix": "\n",
    "margin": 2
  },
  "block_quote": {
    "indent": 1,
    "indent_token": "│ ",
    "color": "#4c566a"
  },
  "paragraph": {},
  "list": {
    "level_indent": 2
  },
  "heading": {
    "block_suffix": "\n",
    "color": "#81a1c1",
    "bold": true
  },
  "h1": {
    "prefix": " ",
    "suffix": " ",
    "color": "#2e3440",
    "background_color": "#81a1c1",
    "bold": true
  },
  "h2": {
    "prefix": "## ",
    "color": "#88c0d0"
  },
  "h3": {
    "prefix": "### ",
    "color": "#81a1c1"
  },
  "h4": {
    "prefix": "#### ",
    "color": "#88c0d0"
  },
  "h5": {
    "prefix": "##### ",
    "color": "#81a1c1"
  },
  "h6": {
    "prefix": "###### ",
    "color": "#4c566a",
    "bold": false
  },
  "text": {},
  "strikethrough": {
    "crossed_out": true
  },
  "emph": {
    "italic": true
  },
  "strong": {
    "bold": true
  },
  "hr": {
    "color": "#4c566a",
    "format": "\n--------\n"
  },
  "item": {
    "block_prefix": "• "
  },
  "enumeration": {
    "block_prefix": ". "
  },
  "task": {
    "ticked": "[✓] ",
    "unticked": "[ ] "
  },
  "link": {
    "color": "#88c0d0",
    "underline": true
  },
  "link_text": {
    "color": "#81a1c1",
    "bold": true
  },
  "image": {
    "color": "#81a1c1",
    "underline": true
  },
  "image_text": {
    "color": "#4c566a",
    "format": "Image: {{.text}} →"
  },
  "code": {
    "prefix": " ",
    "suffix": " ",
    "color": "#a3be8c",
    "background_color": "#4c566a"
  },
  "code_block": {
    "margin": 2,
    "chroma": {
      "text": {},
      "error": {
        "color": "#bf616a"
      },
      "comment": {
        "color": "#4c566a",
        "italic": true
      },
      "comment_preproc": {
        "color": "#ebcb8b"
      },
      "keyword": {
        "color": "#88c0d0"
      },
      "keyword_reserved": {
        "color": "#88c0d0"
      },
      "keyword_namespace": {
        "color": "#88c0d0"
      },
      "keyword_type": {
        "color": "#81a1c1"
      },
      "operator": {
        "color": "#d8dee9"
      },
      "punctuation": {
        "color": "#d8dee9"
      },
      "name": {},
      "name_builtin": {
        "color": "#88c0d0"
      },
      "name_tag": {
        "color": "#81a1c1"
      },
      "name_attribute": {
        "color": "#ebcb8b"
      },
      "name_class": {
        "color": "#81a1c1",
        "bold": true
      },
      "name_constant": {
        "color": "#ebcb8b"
      },
      "name_decorator": {
        "color": "#ebcb8b"
      },
      "name_function": {
        "color": "#81a1c1",
        "bold": true
      },
      "literal": {},
      "literal_number": {
        "color": "#ebcb8b"
      },
      "literal_string": {
        "color": "#a3be8c"
      },
      "literal_string_escape": {
        "color": "#88c0d0"
      },
      "generic_deleted": {
        "color": "#bf616a"
      },
      "generic_emph": {
        "italic": true
      },
      "generic_inserted": {
        "color": "#a3be8c"
      },
      "generic_strong": {
        "bold": true
      },
      "generic_subheading": {
        "color": "#4c566a"
      }
    }
  },
  "table": {},
  "definition_list": {},
  "definition_term": {},
  "definition_description": {
    "block_prefix": "\n🠶 "
  },
  "html_block": {},
  "html_span": {}
}
